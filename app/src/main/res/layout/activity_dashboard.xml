<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg"
    android:paddingHorizontal="28dp"
    android:paddingTop="56dp"
    android:paddingBottom="32dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="40dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_logo"
            android:contentDescription="TicaPlay"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TicaPlay"
                android:textColor="@color/color_white"
                android:textSize="18sp"
                android:fontFamily="serif"/>

            <TextView
                android:id="@+id/tv_welcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_dim"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Botones principales -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿QUÉ QUERÉS VER?"
        android:textColor="@color/color_text_dim"
        android:textSize="11sp"
        android:letterSpacing="0.12"
        android:layout_marginBottom="14dp"/>

    <Button
        android:id="@+id/btn_live"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📺  TV en Vivo"
        android:textColor="@color/color_white"
        android:textSize="16sp"
        android:background="@drawable/bg_button_primary"
        android:layout_marginBottom="12dp"
        android:stateListAnimator="@null"/>

    <Button
        android:id="@+id/btn_movies"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎬  Películas"
        android:textColor="@color/color_white"
        android:textSize="16sp"
        android:background="@drawable/bg_button_secondary"
        android:layout_marginBottom="12dp"
        android:stateListAnimator="@null"/>

    <Button
        android:id="@+id/btn_series"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎭  Series"
        android:textColor="@color/color_white"
        android:textSize="16sp"
        android:background="@drawable/bg_button_secondary"
        android:layout_marginBottom="32dp"
        android:stateListAnimator="@null"/>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Soporte -->
    <Button
        android:id="@+id/btn_support"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="💬  Soporte por WhatsApp"
        android:textColor="@color/color_purple_light"
        android:textSize="14sp"
        android:background="@drawable/bg_button_outline"
        android:layout_marginBottom="10dp"
        android:stateListAnimator="@null"/>

    <!-- Cerrar sesión -->
    <Button
        android:id="@+id/btn_logout"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Cerrar sesión"
        android:textColor="@color/color_text_dim"
        android:textSize="13sp"
        android:background="@android:color/transparent"
        android:stateListAnimator="@null"/>

</LinearLayout>
